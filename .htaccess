# Options
# -MultiViews: impede o Apache de "adivinhar" arquivos por content negotiation,
# o que conflitaria com as regras de rewrite de extensão .html abaixo
Options -MultiViews

# ================================
# Headers de segurança
# ================================
<IfModule mod_headers.c>
    # Impede o navegador de "farejar" o tipo de arquivo e executar algo inesperado
    Header always set X-Content-Type-Options nosniff
    # O site não deve ser embutido em iframes de terceiros (anti-clickjacking)
    Header always set X-Frame-Options DENY
    # Envia apenas a origem (sem path) ao navegar para outros domínios
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    # O site não usa geolocalização, microfone nem câmera — nega tudo
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    # HSTS: obriga o navegador a usar HTTPS por 1 ano após a 1ª visita.
    # Navegadores ignoram este header em conexões HTTP, então é seguro enviá-lo sempre.
    # Só surte efeito depois que o SSL estiver ativo no HostGator (ver DEPLOY-HOSTGATOR.md).
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    # Content-Security-Policy: cobre todas as origens externas que o site usa —
    # Font Awesome (cdnjs), Google Fonts, thumbnails YouTube/acsta/cafecomfilme
    # e embeds de vídeo (YouTube nocookie, Google Drive). 'unsafe-inline' em
    # style-src é necessário pelos <style> dos fallbacks <noscript> e pelo
    # atributo style= de politica-de-privacidade.html.
    # Se algo quebrar após o deploy, o console do navegador mostra a origem
    # bloqueada; adicione-a aqui ou comente a linha para reverter.
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com; font-src 'self' https://cdnjs.cloudflare.com https://fonts.gstatic.com; img-src 'self' data: https://img.youtube.com https://i.ytimg.com https://br.web.img3.acsta.net https://www.cafecomfilme.com.br; frame-src https://www.youtube-nocookie.com https://drive.google.com; connect-src 'self'; base-uri 'self'; form-action 'self'; object-src 'none'"
</IfModule>

# ================================
# Compressão (menos bytes na rede)
# ================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ================================
# Cache do navegador
# CSS/JS podem ter cache de 1 mês porque o site usa cache busting via ?v=
# (mudou o arquivo → muda a versão no link → o navegador baixa de novo).
# HTML fica em 1 dia para atualizações de conteúdo aparecerem rápido.
# ================================
<IfModule mod_expires.c>
    ExpiresActive on
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType font/woff "access plus 1 month"
    ExpiresByType font/woff2 "access plus 1 month"
    ExpiresByType application/pdf "access plus 1 month"
    ExpiresByType text/html "access plus 1 day"
</IfModule>

# Error Pages
ErrorDocument 404 /404.html

# ================================
# Rewrites
# ================================
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Bloqueia artefatos internos e arquivos que nao devem ficar publicos
    # (dotfiles exceto .well-known, .git/.vscode, e docs/scripts de desenvolvimento)
    RewriteRule (^|/)\.(?!well-known(?:/|$)) - [F,L,NC]
    RewriteRule (^|/)(?:\.git|\.vscode)(?:/|$) - [F,L,NC]
    RewriteRule (^|/).+\.(?:md|sql|ya?ml|sh|bat|ps1)$ - [F,L,NC]

    # Força HTTPS (exceto em desenvolvimento local)
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1|\[::1\])(?::\d+)?$ [NC]
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Remove barra final de URLs que não são diretórios (evita conteúdo duplicado no SEO)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{THE_REQUEST} /+([^?]+?)/*[?\s] [NC]
    RewriteRule ^ /%1? [E=VAR:1,R=301,L]

    # URLs limpas: /sobre em vez de /sobre.html (redireciona a versão .html)
    RewriteCond %{THE_REQUEST} /+([^?]+?)\.html[?\s] [NC]
    RewriteRule ^ /%1? [E=VAR:1,R=301,L]

    # ...e serve internamente o arquivo .html correspondente
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^([^./]+)/?$ $1.html [E=VAR:1,L]
</IfModule>
